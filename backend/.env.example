# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/leadgen_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT - GENERATE WITH: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Google Gemini AI - GET FROM: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Encryption Key - GENERATE WITH: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# SendGrid - Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_SIGNING_KEY=your-sendgrid-signing-key-here
WEBHOOK_SECRET=
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000

# ========================================
# v1 FEATURES - Lead Discovery & Enrichment
# ========================================

# Note: Company enrichment uses GEMINI_API_KEY (configured above)
# No additional API key needed - the existing Gemini key is used

# SerpAPI (Optional but Recommended for Lead Discovery)
# Get key from: https://serpapi.com/
# Free tier: 100 searches/month
# Without this, basic Google scraping is used (less reliable)
SERP_API_KEY=

# LinkedIn Enrichment Provider
# Options: clearbit, apollo, snov
ENRICHMENT_PROVIDER=clearbit

# Enrichment API Key (Required for LinkedIn enrichment)
# Clearbit: https://clearbit.com/ (recommended)
# Apollo: https://apollo.io/
# Snov.io: https://snov.io/
ENRICHMENT_API_KEY=
